# ═══════════════════════════════════════════════════════════════════════
# Taskflow self-hosted — perfil FULL (paridade SaaS)
# ═══════════════════════════════════════════════════════════════════════
# Stack completo com MinIO (S3 storage), GlitchTip (error tracking),
# Redis (rate limiting), SMTP (email). ~4GB RAM.
#
# Setup:
#   node scripts/setup-env.mjs full
#   docker compose -f docker/docker-compose.full.yml --env-file .env.local up -d

# ───── Secrets (substituidos pelo setup-env.mjs) ─────
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=changeme-service-role-jwt
POSTGRES_PASSWORD=changeme-strong-random
ENCRYPTION_KEY=changeme-64-hex-chars

# ───── Endpoints ─────
# Ajuste pro IP/dominio da maquina host se acessando de outras maquinas
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ───── Auth ─────
# standard = signup aberto + email verification
# closed   = admin cria users via CLI
AUTH_MODE=standard
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=false

# ───── Email SMTP ─────
EMAIL_DRIVER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

# ───── Storage S3 (MinIO) ─────
STORAGE_DRIVER=s3-compat
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin
STORAGE_S3_BUCKET_PREFIX=taskflow-
# Endpoint publico que o browser acessa pra downloads diretos do MinIO
# Em LAN: http://<ip-do-host>:9000
STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000

# ───── Realtime ─────
REALTIME_DRIVER=pg-notify-sse
NEXT_PUBLIC_REALTIME_DRIVER=pg-notify-sse

# ───── LLM ─────
LLM_DRIVER=disabled
# Descomente pra Ollama local:
# LLM_DRIVER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.1
#
# Ou OpenAI-compat:
# LLM_DRIVER=openai-compat
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o

# ───── Voice Worker (opcional, GPU NVIDIA) ─────
VOICE_DRIVER=disabled
# Descomente se tiver voice-worker rodando:
# VOICE_DRIVER=fastapi
# VOICE_WORKER_URL=http://voice-worker:8080
# VOICE_WORKER_API_KEY=changeme-voice-api-key
# VOICE_WEBHOOK_SECRET=changeme-min-32-chars-webhook-secret

# ───── VCS (GitHub) ─────
VCS_DRIVER=github
VCS_TOKEN_MODE=pat

# ───── Observability (GlitchTip) ─────
# Configure NEXT_PUBLIC_SENTRY_DSN com a DSN do seu projeto no GlitchTip
# Dashboard: http://localhost:8800 (crie org + projeto la)
OBS_DRIVER=glitchtip
NEXT_PUBLIC_SENTRY_DSN=
GLITCHTIP_SECRET_KEY=changeme-glitchtip-secret
GLITCHTIP_DOMAIN=http://localhost:8800
