# ═══════════════════════════════════════════════════════════════════════
# Taskflow self-hosted — perfil FULL (paridade SaaS)
# ═══════════════════════════════════════════════════════════════════════
# Setup: node scripts/setup-env.mjs full

# ───── Secrets (substituidos pelo setup-env.mjs) ─────
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=changeme-service-role-jwt
POSTGRES_PASSWORD=changeme-strong-random
ENCRYPTION_KEY=changeme-64-hex-chars

# ───── Endpoints ─────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════
# AUTH
# ═══════════════════════════════════════════════════════════════════════
AUTH_MODE=standard
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=false
# SOLO_USER_EMAIL=admin@taskflow.local

# GitHub OAuth no login (requer GoTrue com GOTRUE_EXTERNAL_GITHUB_*)
# NEXT_PUBLIC_GITHUB_OAUTH=true

# ═══════════════════════════════════════════════════════════════════════
# STORAGE (MinIO S3)
# ═══════════════════════════════════════════════════════════════════════
STORAGE_DRIVER=s3-compat
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin
STORAGE_S3_BUCKET_PREFIX=taskflow-
STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000
# STORAGE_LOCAL_PATH=/app/storage

# ═══════════════════════════════════════════════════════════════════════
# REALTIME
# ═══════════════════════════════════════════════════════════════════════
REALTIME_DRIVER=pg-notify-sse
NEXT_PUBLIC_REALTIME_DRIVER=pg-notify-sse

# ═══════════════════════════════════════════════════════════════════════
# EMAIL
# ═══════════════════════════════════════════════════════════════════════
EMAIL_DRIVER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
# RESEND_API_KEY=re_xxx

# ═══════════════════════════════════════════════════════════════════════
# LLM (IA)
# ═══════════════════════════════════════════════════════════════════════
LLM_DRIVER=disabled
# GEMINI_API_KEY=xxx
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.1
# LLM_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# VOICE
# ═══════════════════════════════════════════════════════════════════════
VOICE_DRIVER=disabled
# VOICE_DRIVER=fastapi
# VOICE_WORKER_URL=http://voice-worker:8080
# VOICE_WORKER_API_KEY=changeme
# VOICE_WEBHOOK_SECRET=changeme-min-32-chars
# WHISPER_MODEL=large-v3
# HF_TOKEN=hf_xxx

# ═══════════════════════════════════════════════════════════════════════
# VCS (GitHub / Gitea)
# ═══════════════════════════════════════════════════════════════════════
VCS_DRIVER=github
VCS_TOKEN_MODE=pat
# VCS_API_URL=
# VCS_INSTANCE_PAT=ghp_xxx

# ═══════════════════════════════════════════════════════════════════════
# OBSERVABILITY (GlitchTip)
# ═══════════════════════════════════════════════════════════════════════
# Dashboard: http://localhost:8800 — crie org + projeto, copie DSN
OBS_DRIVER=glitchtip
NEXT_PUBLIC_SENTRY_DSN=
GLITCHTIP_SECRET_KEY=changeme-glitchtip-secret
GLITCHTIP_DOMAIN=http://localhost:8800

# ═══════════════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════════════
# Ja configurado no compose full (redis://redis:6379)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
