# ═══════════════════════════════════════════════════════════════════════
# Taskflow self-hosted — perfil SOLO (1 pessoa, home lab)
# ═══════════════════════════════════════════════════════════════════════
# Setup: node scripts/setup-env.mjs solo

# ───── Secrets (substituidos pelo setup-env.mjs) ─────
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=changeme-service-role-jwt
POSTGRES_PASSWORD=changeme-strong-random
ENCRYPTION_KEY=changeme-64-hex-chars

# ───── Endpoints ─────
# Em LAN, troque localhost pelo IP da maquina (ex: http://192.168.1.100:8000)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════
# AUTH
# ═══════════════════════════════════════════════════════════════════════
# solo     = bypass de login, usuario auto-criado
# closed   = admin cria users via CLI, sem signup publico
# standard = signup aberto + email verification
AUTH_MODE=solo
SOLO_USER_EMAIL=admin@taskflow.local

# GitHub OAuth no login (requer GoTrue configurado com GOTRUE_EXTERNAL_GITHUB_*)
# NEXT_PUBLIC_GITHUB_OAUTH=true
# GOTRUE_DISABLE_SIGNUP=true
# GOTRUE_MAILER_AUTOCONFIRM=true

# ═══════════════════════════════════════════════════════════════════════
# STORAGE
# ═══════════════════════════════════════════════════════════════════════
# local-disk = salva em /app/storage (volume Docker)
# s3-compat  = MinIO, AWS S3, R2 (requer STORAGE_S3_* abaixo)
# supabase   = Supabase Storage API (cloud)
STORAGE_DRIVER=local-disk
STORAGE_LOCAL_PATH=/app/storage
# STORAGE_S3_ENDPOINT=http://minio:9000
# STORAGE_S3_ACCESS_KEY=minioadmin
# STORAGE_S3_SECRET_KEY=minioadmin
# STORAGE_S3_BUCKET_PREFIX=taskflow-
# STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000

# ═══════════════════════════════════════════════════════════════════════
# REALTIME
# ═══════════════════════════════════════════════════════════════════════
# pg-notify-sse = driver leve via LISTEN/NOTIFY + SSE (sem container extra)
# supabase      = Supabase Realtime container (Phoenix/Elixir)
# polling       = SWR polling a cada 10s (fallback)
REALTIME_DRIVER=pg-notify-sse
NEXT_PUBLIC_REALTIME_DRIVER=pg-notify-sse

# ═══════════════════════════════════════════════════════════════════════
# EMAIL
# ═══════════════════════════════════════════════════════════════════════
# disabled = convites viram link copiavel
# smtp     = relay externo (Gmail, Mailgun, SES, Resend SMTP)
# resend   = Resend API
# console  = loga email em stdout (dev)
EMAIL_DRIVER=disabled
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_SECURE=false
# RESEND_API_KEY=re_xxx

# ═══════════════════════════════════════════════════════════════════════
# LLM (IA)
# ═══════════════════════════════════════════════════════════════════════
# disabled     = botoes de IA somem da UI
# gemini       = Google Gemini (requer GEMINI_API_KEY)
# ollama       = Ollama local (requer LLM_BASE_URL)
# openai-compat = qualquer API OpenAI-compatible
# anthropic    = Claude API
LLM_DRIVER=disabled
# NEXT_PUBLIC_AI_ENABLED=true
# GEMINI_API_KEY=xxx
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.1
# LLM_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# VOICE (transcrição de reuniões)
# ═══════════════════════════════════════════════════════════════════════
# disabled = tab "Gravar" some na UI
# fastapi  = worker externo com GPU (requer VOICE_WORKER_URL)
VOICE_DRIVER=disabled
# VOICE_WORKER_URL=http://voice-worker:8080
# VOICE_WORKER_API_KEY=changeme
# VOICE_WEBHOOK_SECRET=changeme-min-32-chars

# ═══════════════════════════════════════════════════════════════════════
# VCS (GitHub / Gitea)
# ═══════════════════════════════════════════════════════════════════════
# github   = GitHub API (default)
# gitea    = Gitea (requer VCS_API_URL)
# disabled = aba Repos some
VCS_DRIVER=github
# Token mode: oauth = botao OAuth, pat = user cola PAT em Settings,
# instance-pat = 1 PAT global pra todo instance
VCS_TOKEN_MODE=pat
# VCS_API_URL=https://gitea.example.com/api/v1
# VCS_INSTANCE_PAT=ghp_xxx

# ═══════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════
# console   = stderr only
# sentry    = Sentry SaaS
# glitchtip = GlitchTip self-hosted (Sentry-compat)
# noop      = descarta tudo
OBS_DRIVER=console
# NEXT_PUBLIC_SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════
# REDIS (rate limiting)
# ═══════════════════════════════════════════════════════════════════════
# Se nao setado, usa in-memory (suficiente pra 1 container app)
# REDIS_URL=redis://redis:6379
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
