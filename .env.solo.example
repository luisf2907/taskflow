# ═══════════════════════════════════════════════════════════════════════
# Taskflow self-hosted — perfil SOLO (1 pessoa, home lab)
# ═══════════════════════════════════════════════════════════════════════
# Stack:
#   - postgres (com pgvector)
#   - gotrue (closed: sem signup, sem email)
#   - app (Next.js standalone)
#
# Features ativas:
#   - Kanban, wiki, sprints, planning poker, cartoes, comentarios
#   - GitHub integracao via PAT (se voce colar em Settings)
#
# Features desativadas (podem ser ligadas editando este arquivo):
#   - IA (Gemini/Ollama)
#   - Email
#   - Reunioes com transcricao (voice worker)
#   - Realtime via Supabase Realtime (usa driver leve pg-notify-sse)
#
# Copiar para .env.local antes do primeiro `docker compose up`.

# ───── Secrets gerados pelo bootstrap ─────
# Rode `bash scripts/gen-secrets.sh >> .env.local` pra gerar com valores seguros.
# Os valores abaixo sao placeholders — SUBSTITUIR antes de rodar.

# JWT secret usado pelo GoTrue (32+ chars)
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32

# Anon key e service role key sao JWTs assinados com JWT_SECRET.
# Gere com scripts/gen-secrets.sh.
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=changeme-service-role-jwt

# Senha do postgres (usuario postgres)
POSTGRES_PASSWORD=changeme-strong-random

# Encryption key (AES-256-GCM, 64 hex chars = 32 bytes).
# IMPORTANTE: nao trocar depois do primeiro uso, senao tokens encriptados
# (GitHub PATs, API keys) ficam irrecuperaveis.
ENCRYPTION_KEY=changeme-64-hex-chars

# ───── Supabase self-hosted endpoints ─────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ───── Drivers (tudo em modo mais leve por default no solo) ─────

# Auth: solo = bypass de login, usuario auto-criado no bootstrap
AUTH_MODE=solo
SOLO_USER_EMAIL=admin@taskflow.local

# Storage: local-disk salva uploads em ./storage (volume do container app)
STORAGE_DRIVER=local-disk
STORAGE_LOCAL_PATH=/app/storage

# Realtime: pg-notify-sse elimina container Supabase Realtime.
# Precisa tambem em NEXT_PUBLIC_ porque features.ts usa no client,
# e Next so preserva envs NEXT_PUBLIC_* no bundle cliente.
REALTIME_DRIVER=pg-notify-sse
NEXT_PUBLIC_REALTIME_DRIVER=pg-notify-sse

# LLM desligado por default; descomente pra ligar
LLM_DRIVER=disabled
# LLM_DRIVER=ollama
# LLM_BASE_URL=http://ollama:11434
# LLM_MODEL=llama3.1

# Email desligado — convites geram link copiavel
EMAIL_DRIVER=disabled

# Voice desligado — sem transcricao de reunioes
VOICE_DRIVER=disabled
# Pra ligar, voce precisa do worker FastAPI rodando em maquina separada com GPU.

# VCS: GitHub via PAT (usuario cola em Settings) ou instance-pat (global)
VCS_DRIVER=github
VCS_TOKEN_MODE=pat
# Se preferir 1 PAT global pra todo o instance (home lab), troque pra:
# VCS_TOKEN_MODE=instance-pat
# VCS_INSTANCE_PAT=ghp_xxx

# Observability: console (stderr)
OBS_DRIVER=console
