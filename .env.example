# ===========================================
# Taskflow — Environment Variables
# ===========================================
# Copie este arquivo para .env.local e preencha os valores.
# Variaveis marcadas como "required" quebram o boot do servidor se faltarem
# (validacao via Zod em src/lib/env.ts).

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Encryption (required) ---
# AES-256-GCM key para dados sensiveis (GitHub tokens, API keys no DB).
# Sem isso o server nao sobe. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: rotacionar essa chave em producao invalida todos os tokens ja
# encriptados — planeje migracao se for trocar.
ENCRYPTION_KEY=your-64-hex-chars-key

# --- Site URL (optional, defaults to https://taskflow.app) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI / Gemini (optional — enables AI card generation/enhancement) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Resend (optional — enables email notifications) ---
RESEND_API_KEY=re_your-resend-api-key

# --- Sentry (optional em dev, recomendado em producao) ---
# Error tracking (client + server + edge).
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# --- Upstash Redis (optional — enables reliable rate limiting in serverless) ---
# Create free instance at https://console.upstash.com
# Sem isso, rate limiting usa cache in-memory (nao confiavel em serverless).
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- TaskFlow Voice worker (optional — enables voice features) ---
# FastAPI + pyannote/whisper em maquina com GPU, exposto via ngrok.
# Se nao preencher, a tela de Voz mostra "worker indisponivel".
VOICE_WORKER_URL=https://your-tunnel.ngrok-free.app
VOICE_WORKER_API_KEY=your-shared-secret
# HMAC secret (min 32 chars) para validar callbacks do worker de voz
# em /api/reunioes/[id]/webhook. Sem isso, qualquer um que adivinhe a URL
# pode postar resultado de transcricao falso.
VOICE_WEBHOOK_SECRET=your-32-plus-char-random-secret
