# ═══════════════════════════════════════════════════════════════════════
# Taskflow — Cloud (Vercel + Supabase Cloud + SaaS)
# ═══════════════════════════════════════════════════════════════════════
# Para deploy na Vercel ou dev local com Supabase Cloud. Sem Docker.
#
# Setup:
#   1. cp .env.example .env.local
#   2. Preencha os valores do seu projeto Supabase (abaixo)
#   3. Gere ENCRYPTION_KEY:
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   4. Configure o banco de dados:
#        Siga o guia em supabase/cloud/README.md
#   5. npm install && npm run dev

# ═══════════════════════════════════════════════════════════════════════
# SUPABASE (obrigatórios — do dashboard do seu projeto)
# ═══════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Site URL (Vercel: https://seu-app.vercel.app, dev: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════
# ENCRYPTION (obrigatória)
# ═══════════════════════════════════════════════════════════════════════
# AES-256-GCM, 64 hex chars. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: rotacionar invalida tokens ja encriptados — use CLI token:rotate.
ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════════
# AUTH
# ═══════════════════════════════════════════════════════════════════════
# No cloud, auth é gerenciado pelo Supabase (signup, OAuth, email confirm).
# Não precisa de AUTH_MODE — default é "standard".

# GitHub OAuth no login (configure em Supabase Dashboard > Auth > Providers)
# NEXT_PUBLIC_GITHUB_OAUTH=true

# ═══════════════════════════════════════════════════════════════════════
# LLM (IA — geração de cards, enhance, resumo de reunião)
# ═══════════════════════════════════════════════════════════════════════
# Sem key = botões de IA somem da UI
# GEMINI_API_KEY=

# Ou OpenAI-compat / Anthropic:
# LLM_DRIVER=openai-compat
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o

# ═══════════════════════════════════════════════════════════════════════
# EMAIL (convites, notificações)
# ═══════════════════════════════════════════════════════════════════════
# Sem key = convites viram link copiável
# RESEND_API_KEY=re_xxx

# Ou SMTP:
# EMAIL_DRIVER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_SECURE=false

# ═══════════════════════════════════════════════════════════════════════
# VOICE (transcrição de reuniões — worker externo com GPU)
# ═══════════════════════════════════════════════════════════════════════
# Sem URL = tab "Gravar" some da UI
# VOICE_WORKER_URL=https://xxx.ngrok-free.app
# VOICE_WORKER_API_KEY=
# VOICE_WEBHOOK_SECRET=changeme-min-32-chars

# ═══════════════════════════════════════════════════════════════════════
# OBSERVABILITY (Sentry)
# ═══════════════════════════════════════════════════════════════════════
# Sem DSN = erro tracking desligado (stderr only)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ═══════════════════════════════════════════════════════════════════════
# RATE LIMITING (Upstash Redis — serverless)
# ═══════════════════════════════════════════════════════════════════════
# Sem URL = fallback in-memory (funciona em dev, fragil em prod multi-instance)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# VCS (GitHub)
# ═══════════════════════════════════════════════════════════════════════
# Default: OAuth (botão "conectar com GitHub" em Settings do workspace)
# Troque pra PAT se não configurou OAuth no Supabase Auth:
# VCS_TOKEN_MODE=pat
