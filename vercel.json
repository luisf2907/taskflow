{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build",
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/reunioes/[id]/process/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reunioes/[id]/webhook/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/ai/**/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/voice/enroll/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
