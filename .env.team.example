# ═══════════════════════════════════════════════════════════════════════
# Taskflow self-hosted — perfil TEAM (2-20 pessoas, LAN/VPN)
# ═══════════════════════════════════════════════════════════════════════
# Stack:
#   - postgres (com pgvector)
#   - gotrue (closed: admin cria users via CLI)
#   - redis (rate limiting compartilhado)
#   - app (Next.js standalone)
#
# Features ativas:
#   - Kanban, wiki, sprints, planning poker, cartoes, comentarios
#   - GitHub integracao via PAT (cada user cola em Settings)
#   - Email SMTP (convites, notificacoes)
#   - Rate limiting compartilhado via Redis
#   - Users trocam senha no primeiro login
#
# Features desativadas (podem ser ligadas editando este arquivo):
#   - IA (Gemini/Ollama) — descomente LLM_DRIVER abaixo
#   - Reunioes com transcricao (voice worker — precisa GPU)
#
# Setup:
#   node scripts/setup-env.mjs team      # gera .env.local com secrets
#   docker compose -f docker/docker-compose.team.yml --env-file .env.local up -d
#   node --env-file=.env.local scripts/cli.mjs bootstrap \
#     --admin-email admin@team.local --admin-password changeme
#   node --env-file=.env.local scripts/cli.mjs user:create \
#     --email user@team.local --password temp123 --name "Nome"

# ───── Secrets (substituidos pelo setup-env.mjs) ─────
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=changeme-service-role-jwt
POSTGRES_PASSWORD=changeme-strong-random
ENCRYPTION_KEY=changeme-64-hex-chars

# ───── Supabase self-hosted endpoints ─────
# Ajuste pra IP da maquina host se acessando de outras maquinas na LAN
# (ex: http://192.168.1.100:8000)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ───── Auth ─────
# closed = admin cria users via CLI, sem signup publico
AUTH_MODE=closed

# ───── Storage ─────
STORAGE_DRIVER=local-disk
STORAGE_LOCAL_PATH=/app/storage

# ───── Realtime ─────
REALTIME_DRIVER=pg-notify-sse
NEXT_PUBLIC_REALTIME_DRIVER=pg-notify-sse

# ───── Email SMTP ─────
# Configure com seu relay SMTP (Gmail, Mailgun, SES, etc).
# Exemplo Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
#   SMTP_USER=seu-email@gmail.com, SMTP_PASSWORD=app-password-de-16-chars
EMAIL_DRIVER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

# ───── LLM ─────
# Descomente pra ligar IA (Ollama local ou OpenAI-compat)
LLM_DRIVER=disabled
# LLM_DRIVER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.1

# ───── Voice ─────
VOICE_DRIVER=disabled

# ───── VCS (GitHub) ─────
VCS_DRIVER=github
VCS_TOKEN_MODE=pat
# Se preferir 1 PAT global pra todo o instance:
# VCS_TOKEN_MODE=instance-pat
# VCS_INSTANCE_PAT=ghp_xxx

# ───── Observability ─────
OBS_DRIVER=console
